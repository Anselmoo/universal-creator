// Receives JSON on stdin via Node.js process.stdin.
// Write JSON to process.stdout to return a decision.
// Exit 0 = allow.  Exit 1 = block.
//
// See: https://docs.anthropic.com/en/docs/claude-code/hooks

process.stdin.setEncoding("utf8");
let input = "";
process.stdin.on("data", (chunk) => (input += chunk));
process.stdin.on("end", () => {
  let payload;
  try {
    payload = JSON.parse(input);
  } catch {
    process.stdout.write(JSON.stringify({ decision: "allow" }) + "\n");
    process.exit(0);
  }

  // TODO: inspect payload and implement hook logic
  // const toolName = payload?.tool_name;

  process.stdout.write(
    JSON.stringify({ decision: "allow", reason: "TODO: explain decision" }) + "\n"
  );
  process.exit(0);
});
