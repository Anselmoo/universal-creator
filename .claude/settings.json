{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume|clear|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/sync_agents.py"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "async": false,
                        "command": "python3 .claude/hooks/sync_agents.py"
                    }
                ]
            }
        ]
    }
}
